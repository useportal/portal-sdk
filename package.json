{
  "name": "portalsdk",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.7.1",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" build",
    "test": "vitest run",
    "typecheck": "pnpm -r --filter \"./packages/*\" typecheck",
    "lint": "pnpm -r --filter \"./packages/*\" lint",
    "check:registry": "node scripts/check-registry-closure.mjs"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
