{
  "name": "@portalsdk/core",
  "version": "0.1.3",
  "description": "Transport-agnostic Portal client runtime, built on the wire protocol over a WebSocket.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/useportal/portal-sdk.git",
    "directory": "packages/core"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "prepublishOnly": "node ../../scripts/verify-publish-manifest.mjs"
  },
  "dependencies": {
    "@portalsdk/wire-protocol": "workspace:^",
    "partysocket": "1.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.18.8",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
