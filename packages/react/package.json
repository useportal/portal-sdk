{
  "name": "@portalsdk/react",
  "version": "0.0.0",
  "description": "React bindings — hooks and providers wrapping the Portal core client.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/useportal/portal-sdk.git",
    "directory": "packages/react"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@portalsdk/core": "workspace:^"
  },
  "peerDependencies": {
    "react": ">=18 <20"
  },
  "devDependencies": {
    "@types/node": "^22.18.8",
    "@types/react": "^19.2.2",
    "react": "^19.2.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
